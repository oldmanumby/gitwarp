{
  "name": "app-gitwarp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:docs": "blume build --base /docs && mv dist docs_temp",
    "build:app": "vite build",
    "build": "bun run build:docs && bun run build:app && mv docs_temp dist/docs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "release": "standard-version",
    "postrelease": "git push --follow-tags origin dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "blume": "^1.1.3",
    "eslint": "^10.7.0",
    "fallow": "^3.7.1",
    "husky": "^9.1.7",
    "prettier": "^3.9.6",
    "standard-version": "^9.5.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "lucide": "^1.21.0"
  }
}
